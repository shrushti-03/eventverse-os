# EVENTVERSE OS Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=EVENTVERSE OS
DEBUG=True

# Database (use SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./eventverse.db
# DATABASE_URL=postgresql://user:password@localhost:5432/eventverse

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML APIs (optional)
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
